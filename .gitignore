# ============================================================================
# ClaudeSec — .gitignore
# Ignore everything except the project files
# ============================================================================

# Ignore everything by default
/*

# ============================================================================
# Project files (whitelist)
# ============================================================================
!CLAUDE.md
!README.md
!CLAUDESEC.md
!docs/
!scripts/
!.gitignore
!LICENSE

# Allow nested files in docs/
!docs/**
!scripts/**

# ============================================================================
# OS files
# ============================================================================
.DS_Store
Thumbs.db
Desktop.ini

# ============================================================================
# Secrets & Environment
# ============================================================================
.env
.env.*
*.pem
*.key
*.cert
credentials.json

# ============================================================================
# Tool outputs
# ============================================================================
results/
output/
*.nmap
*.gnmap
*.xml
*.html
*.log

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.venv/
venv/

# ============================================================================
# IDE
# ============================================================================
.vscode/
.idea/
*.iml

# ============================================================================
# Git
# ============================================================================
.git/
